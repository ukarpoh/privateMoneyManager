BOT_TOKEN=your_telegram_bot_token_here
KIMI_API_KEY=your_kimi_api_key_here

# Optional: currency symbol shown in all displays (default: RM)
CURRENCY_SYMBOL=RM

# ─── DATA PATHS ──────────────────────────────────────────────────────────────
# The Dockerfile already sets DB_PATH=/data/budget_bot.db and
# LOG_PATH=/data/budget_bot.log pointing at the persistent Railway Volume.
#
# !! DO NOT add DB_PATH or LOG_PATH to Railway's "Variables" panel !!
# An env-var override there will replace the /data/... default and put the
# database inside the ephemeral container layer, causing data loss on deploy.
#
# Only uncomment these when running locally OUTSIDE Docker:
# DB_PATH=budget_bot.db
# LOG_PATH=budget_bot.log
